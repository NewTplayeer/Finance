rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Dados pessoais ──────────────────────────────────────────────────────
    // Apenas o próprio utilizador pode ler/escrever os seus dados
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Espaços partilhados ─────────────────────────────────────────────────
    // Qualquer utilizador autenticado pode ler/escrever num espaço partilhado
    // (o código do espaço funciona como chave de acesso)
    match /artifacts/{appId}/sharedSpaces/{spaceId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
